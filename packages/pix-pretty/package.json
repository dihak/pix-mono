		"directory": "packages/pix-pretty"
	},
	"homepage": "https://github.com/xynogen/pix-mono/tree/main/packages/pix-pretty#readme",
	"bugs": {
		"url": "https://github.com/xynogen/pix-mono/issues"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"dependencies": {
		"cli-highlight": "^2.1.11",
		"@ff-labs/fff-node": "^0.5.2",
