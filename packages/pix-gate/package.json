{
	"name": "@dihak/pix-gate",
	"version": "0.1.15",
	"description": "Pi extension — permission gate for dangerous bash commands (confirm/block with TUI dialog)",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./lib": "./src/lib.ts",
		"./prompt": "./src/prompt.ts",
		"./src/*": "./src/*"
	},
	"scripts": {
		"test": "bun test"
	},
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"src/index.ts"
		]
	},
	"keywords": [
		"pi",
		"pi-package",
		"pi-extension",
		"security",
		"permission",
		"gate"
	],
	"author": "dihak",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dihak/pix-mono.git",
		"directory": "packages/pix-gate"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@dihak/pix-pretty": "^1.7.9",
		"@dihak/pix-data": "^0.3.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	}
}
