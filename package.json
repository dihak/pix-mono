{
	"name": "pix-mono",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo of Pi Coding Agent extensions (pix-*)",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"install:deps": "bun install --frozen-lockfile",
		"dev": "bun test --watch",
		"test": "bun test",
		"test:unit": "bun test",
		"test:tidy": "rm -rf coverage",
		"typecheck": "tsc --noEmit -p tsconfig.base.json",
		"lint": "biome lint packages",
		"lint:check": "biome lint packages",
		"lint:fix": "biome lint --write packages",
		"format": "biome format --write packages",
		"format:fix": "biome format --write packages",
		"format:check": "biome format packages",
		"check": "biome check packages",
		"check:fix": "biome check --write packages",
		"ci": "biome ci",
		"distro:install": "bash scripts/install.sh",
		"distro:uninstall": "bash scripts/uninstall.sh",
		"dev:link": "bash scripts/dev-link.sh",
		"dev:unlink": "bash scripts/dev-link.sh --unlink",
		"publish:all": "bun scripts/publish-all.ts",
		"publish:dry": "bun scripts/publish-all.ts --dry-run"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@earendil-works/pi-ai": "latest",
		"@earendil-works/pi-coding-agent": "latest",
		"@earendil-works/pi-tui": "latest",
		"@types/bun": "latest",
		"@types/node": "^22",
		"typebox": "^1.1.38",
		"typescript": "^5.7.0"
	},
	"engines": {
		"bun": ">=1.1.0"
	}
}
