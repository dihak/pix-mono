{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"baseUrl": ".",
		"paths": {
			"@xynogen/pix-data": ["packages/pix-data/src/index.ts"],
			"@xynogen/pix-data/collapse": ["packages/pix-data/src/collapse.ts"],
			"@xynogen/pix-data/pix-config": ["packages/pix-data/src/pix-config.ts"],
			"@xynogen/pix-skills": ["packages/pix-skills/src/index.ts"],
			"@xynogen/pix-gate/lib": ["packages/pix-gate/src/lib.ts"]
		},
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"types": ["bun"]
	},
	"include": ["packages/*/src/**/*.ts"],
	"exclude": ["**/node_modules/**", "**/dist/**"]
}
