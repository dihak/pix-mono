{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["packages/**/*.ts", "packages/**/*.json", "*.json"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noControlCharactersInRegex": "off",
				"noExplicitAny": "off",
				"noFallthroughSwitchClause": "error",
				"noDoubleEquals": "error",
				"noVar": "error"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "warn",
				"noUnusedPrivateClassMembers": "warn",
				"noInvalidUseBeforeDeclaration": "error"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": { "maxAllowedComplexity": 100 }
				},
				"noForEach": "off",
				"noUselessTernary": "warn",
				"noUselessConstructor": "warn"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "warn",
				"noParameterAssign": "off"
			},
			"performance": {
				"noAccumulatingSpread": "error",
				"noDelete": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
